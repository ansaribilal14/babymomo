<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BABYMOMO" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
    <style name="Theme.BABYMOMO.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/warm_cream</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.BABYMOMO</item>
    </style>
</resources>
